#!/usr/bin/env bash
# Spawns a zellij session in a new terminal from a path read via stdin.
# Intended for use with: ls-projects | dmenu | zellij-sessionizer

IFS= read -r path
[[ -z $path ]] && exit 0

path="${path/#\~/$HOME}"
name=$(basename "$path")

zoxide add "$path" &
cd "$path" && ${TERMINAL:-alacritty} --working-directory "$path" -e zellij --layout code attach --create "$name"
