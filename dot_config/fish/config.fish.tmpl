# sourcing
if test -e /usr/share/cachyos-fish-config/cachyos-config.fish
    source /usr/share/cachyos-fish-config/cachyos-config.fish
end
{{ (rbw "~/.config/fish/config.fish").notes }}

# remove greeting
function fish_greeting
end

# env vars
set -gx XDG_CACHE_HOME "$HOME"/.cache
set -gx XDG_CONFIG_HOME "$HOME"/.config
set -gx XDG_DATA_HOME "$HOME"/.local/share
set -gx XDG_STATE_HOME "$HOME"/.local/state

set -gx GOPRIVATE "github.com/kevincali/*"
set -gx GOPATH "$XDG_DATA_HOME"/go

set -gx PATH "$PATH:$HOME/.cargo/bin"

set -gx EDITOR /home/cake/.cargo/bin/hx
set -gx TERMINAL alacritty

if status is-interactive
    # sourcing
    if type -q atuin
        atuin init fish --disable-up-arrow | source
    end
    if type -q direnv
        direnv hook fish | source
    end
    if type -q zoxide
        zoxide init fish | source
    end

    # options
    set fzf_fd_opts --hidden --no-ignore

    # aliases
    alias e="zellij --layout code"
    alias ka="killall"
    alias lg="lazygit"
    alias lt='eza -al --sort=modified --color=always --group-directories-first --icons' # recently modified

    # hotkeys
    bind -M insert \ce forward-bigword # Ctrl+E
    bind -M insert \cb backward-bigword # Ctrl+B

    fish_vi_key_bindings
    set fish_cursor_insert line
    set fish_cursor_replace_one underscore
    set fish_cursor_visual block
    set fish_vi_force_cursor
end
